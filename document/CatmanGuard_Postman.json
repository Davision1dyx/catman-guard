          "response": []
        },
        {
          "name": "创建知识库",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/knowledge/create",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "knowledge", "create"]
