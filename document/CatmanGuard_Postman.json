              "mode": "formdata",
              "formdata": [
                {"key": "file", "type": "file", "description": "要上传的文件"},
                {"key": "title", "value": "文件标题", "type": "text", "description": "文件标题"},
                {"key": "softwareVersion", "value": "", "type": "text", "description": "软件版本"},
                {"key": "feature", "value": "", "type": "text", "description": "特性标签"},
                {"key": "microservice", "value": "", "type": "text", "description": "所属微服务"},
                {"key": "description", "value": "", "type": "text", "description": "文件描述"}
              ]
            },
            "description": "上传文件到指定知识库"
          },
          "response": []
        },
        {
          "name": "获取文件列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/file/list/{{knowledgeId}}?search={{search}}&fileType={{fileType}}&status={{status}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "file", "list", "{{knowledgeId}}"],
              "query": [
                {"key": "search", "value": "{{search}}", "description": "搜索关键词"},
                {"key": "fileType", "value": "{{fileType}}", "description": "文件类型筛选"},
                {"key": "status", "value": "{{status}}", "description": "状态筛选"}
              ]
            },
            "description": "获取指定知识库下的文件列表"
          },
          "response": []
        },
        {
          "name": "删除文件",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/file/{{fileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "file", "{{fileId}}"]
            },
            "description": "删除指定的文件"
          },
          "response": []
        },
        {
          "name": "执行文件分片",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/chunk/chunk/{{fileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "chunk", "chunk", "{{fileId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"chunkType\": \"fixed_length\", \"chunkSize\": 1000, \"chunkOverlap\": 100}"
            },
            "description": "对上传的文件执行分片处理"
          },
          "response": []
        },
        {
          "name": "获取分片信息",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/chunk/list/{{fileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "chunk", "list", "{{fileId}}"]
            },
            "description": "获取指定文件的分片信息"
          },
          "response": []
        },
        {
          "name": "同步向量库",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/embed/sync/{{knowledgeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "embed", "sync", "{{knowledgeId}}"]
            },
            "description": "同步知识库的向量库"
