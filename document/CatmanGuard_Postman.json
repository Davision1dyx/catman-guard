{
  "info": {
    "_postman_id": "catman-guard-api-collection",
    "name": "Catman Guard API",
    "description": "Catman Guard 智能问答与工单管理系统接口协议",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "智能问答模块",
      "item": [
        {
          "name": "普通聊天接口",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/conversation/chat/chat?message={{message}}&conversationId={{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "conversation", "chat", "chat"],
              "query": [
                {"key": "message", "value": "{{message}}", "description": "用户输入的消息内容"},
                {"key": "conversationId", "value": "{{conversationId}}", "description": "对话ID，用于标识会话"}
              ]
            },
            "description": "普通聊天接口，返回流式文本响应"
          },
          "response": []
        },
        {
          "name": "网页搜索聊天接口",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/conversation/chat/websearch?message={{message}}&conversationId={{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "conversation", "chat", "websearch"],
              "query": [
                {"key": "message", "value": "{{message}}", "description": "用户输入的消息内容"},
                {"key": "conversationId", "value": "{{conversationId}}", "description": "对话ID，用于标识会话"}
              ]
            },
            "description": "网页搜索聊天接口，结合网络搜索返回答案"
          },
          "response": []
        },
        {
          "name": "检索聊天接口",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/conversation/chat/retrieavl?message={{message}}&conversationId={{conversationId}}",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "conversation", "chat", "retrieavl"],
              "query": [
                {"key": "message", "value": "{{message}}", "description": "用户输入的消息内容"},
                {"key": "conversationId", "value": "{{conversationId}}", "description": "对话ID，用于标识会话"}
              ]
            },
            "description": "检索聊天接口，从知识库检索相关内容回答"
          },
          "response": []
        }
      ]
    },
    {
      "name": "知识库管理模块",
      "item": [
        {
          "name": "获取知识库列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/processing/catman/storage/knowledge/list",
              "host": ["{{baseUrl}}"],
              "path": ["processing", "catman", "storage", "knowledge", "list"]
